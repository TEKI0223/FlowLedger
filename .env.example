# 复制为 .env.local，把值填好，Next.js 启动时会自动读。

# 数据库连接
# 本地：file:./data/flowledger.db
# 生产（Vercel + Turso）：libsql:// 加 AUTH_TOKEN
DATABASE_URL=file:./data/flowledger.db
# DATABASE_AUTH_TOKEN=<turso db tokens create 输出，仅生产>

# 访问密码（必需）— 整站登录用。本地随便设一个，生产用强密码。
# 改密码会立即作废所有现存 session（JWT secret 派生自密码）。
FLOWLEDGER_PASSWORD=devpassword
